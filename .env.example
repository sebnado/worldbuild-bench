# Provider API keys — set only the ones you need for the models you run.
# Copy to .env (gitignored); wb loads it automatically (cwd first, then the
# package root). Real environment variables always win over .env values.
# See models.json for which key each model uses.

# Anthropic (Messages API) — claude-* models (Fable 5, Opus 4.8, Sonnet 5, Haiku 4.5)
ANTHROPIC_API_KEY=

# OpenAI (Responses API) — gpt-* models (GPT-5.5)
OPENAI_API_KEY=

# Google (Gemini generateContent) — gemini-* models (Gemini 3.1 Pro)
GEMINI_API_KEY=

# OpenRouter (OpenAI-compatible) — glm / minimax / qwen / kimi / deepseek / grok entries
OPENROUTER_API_KEY=

# Groq (OpenAI-compatible) — optional, for models you add pointing at Groq
GROQ_API_KEY=

# Cerebras (OpenAI-compatible) — optional, for models you add pointing at Cerebras
CEREBRAS_API_KEY=
